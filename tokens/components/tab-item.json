            }
          },
          "icon": {
            "default": {
              "value": "{color.icon.neutral.default}",
              "type": "color",
              "$description": "Default icon color for neutral tab - matches text color"
            },
            "hover": {
              "value": "{color.icon.neutral.intense.0}",
              "type": "color",
              "$description": "Icon color when hovering over neutral tab - darker shade"
