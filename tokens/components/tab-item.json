            },
            "disabled": {
              "value": "{color.background.transparent}",
              "type": "color",
              "$description": "Background for disabled primary tab - transparent"
            }
          },
          "border": {
            "bottom": {
              "default": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Default bottom border for primary tab - transparent (no border)"
              },
              "hover": {
                "value": "{color.border.primary.subtle.1}",
                "type": "color",
                "$description": "Bottom border when hovering over primary tab - light primary"
              },
              "active": {
                "value": "{color.border.primary.default}",
                "type": "color",
                "$description": "Bottom border for active primary tab - primary blue (#004EEB) 2px"
              },
              "focused": {
                "value": "{color.border.primary.subtle.1}",
                "type": "color",
                "$description": "Bottom border when primary tab is focused - light primary"
              },
              "disabled": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Bottom border for disabled primary tab - transparent"
              }
            },
            "side": {
              "default": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Default side borders for primary tab - transparent (line tabs have no side borders)"
              },
              "hover": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders on hover for primary tab - transparent"
              },
              "active": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders for active primary tab - transparent"
              },
              "focused": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders when primary tab is focused - transparent"
              },
              "disabled": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders for disabled primary tab - transparent"
              }
            }
          },
          "text": {
            "default": {
              "value": "{color.text.primary.body.1}",
              "type": "color",
