        "md": {
          "value": "{size.height.xs}",
          "type": "dimension",
          "$description": "Height of icon-only tab item - 32px"
        },
        "lg": {
          "value": "{size.height.md}",
          "type": "dimension",
          "$description": "Height of icon-only tab item - 40px"
        },
        "xl": {
          "value": "{size.height.md}",
          "type": "dimension",
          "$description": "Height of icon-only tab item - 40px"
        },
        "2xl": {
          "value": "{size.height.md}",
          "type": "dimension",
          "$description": "Height of icon-only tab item - 40px"
        }
      }
    },
    "width": {
      "icon-only": {
        "sm": {
          "value": "{size.width.3xs}",
