{
  "tab-item": {
    "border": {
      "radius": {
        "line": {
          "value": "{border.radius.xs}",
          "type": "dimension",
          "$description": "Border radius for tab item - 4px (applied to top corners only for line tabs)"
        },
        "segment": {
          "value": "{border.radius.xs}",
          "type": "dimension",
          "$description": "Border radius for segment tabs - 6px, applied to all corners"
        }
      },
      "width": {
        "line": {
          "active": {
            "sm": {
              "value": "{border.width.sm}",
              "type": "dimension",
              "$description": "Bottom border width for active tab state - 1.5px"
            },
            "md": {
              "value": "{border.width.md}",
              "type": "dimension",
              "$description": "Bottom border width for active tab state - 2px"
            },
            "lg": {
              "value": "{border.width.md}",
              "type": "dimension",
              "$description": "Bottom border width for active tab state - 2px"
            },
            "xl": {
              "value": "{border.width.md}",
              "type": "dimension",
              "$description": "Bottom border width for active tab state - 2px"
            },
            "2xl": {
              "value": "{border.width.md}",
              "type": "dimension",
              "$description": "Bottom border width for active tab state - 2px"
            }
          }
        }
      }
    },
    "padding": {
      "x": {
        "default": {
          "value": "{padding.x.3xs}",
          "type": "dimension",
          "$description": "Horizontal padding for default tab item - 8px"
        },
        "icon-only": {
          "value": "{padding.x.none}",
          "type": "dimension",
          "$description": "Horizontal padding for icon-only tab item - 0px"
        }
      },
      "y": {
        "default": {
          "value": "{padding.y.1}",
          "type": "dimension",
          "$description": "Vertical padding for sm tab item - 4px"
        },
        "icon-only": {
          "value": "{padding.y.none}",
          "type": "dimension",
          "$description": "Vertical padding for icon-only tab item - 0px"
          }
      }
    },
    "height": {
      "default": {
        "sm": {
          "value": "{size.height.3xs}",
          "type": "dimension",
          "$description": "Height of sm tab item - 24px"
        },
        "md": {
          "value": "{size.height.xs}",
          "type": "dimension",
          "$description": "Height of md tab item - 32px"
        },
        "lg": {
          "value": "{size.height.md}",
          "type": "dimension",
          "$description": "Height of lg tab item - 40px"
        },
        "xl": {
          "value": "{size.height.md}",
          "type": "dimension",
          "$description": "Height of xl tab item - 40px"
