              },
              "active": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders for active neutral tab - transparent"
              },
              "focused": {
                "value": "{color.border.transparent}",
                "type": "color",
                "$description": "Side borders when neutral tab is focused - transparent"
              },
              "disabled": {
                "value": "{color.border.transparent}",
                "type": "color",
