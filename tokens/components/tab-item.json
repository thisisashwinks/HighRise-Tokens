            "hover": {
              "value": "{color.text.primary.title.1}",
              "type": "color",
              "$description": "Text color when hovering over primary tab - darker gray (#1D2939)"
            },
            "active": {
              "value": "{color.text.primary.title.1}",
              "type": "color",
              "$description": "Text color for active primary tab - primary blue (#004EEB), weight changes to Semibold"
            },
            "focused": {
              "value": "{color.text.primary.title.1}",
              "type": "color",
              "$description": "Text color when primary tab is focused - darker gray (#1D2939)"
            },
            "disabled": {
              "value": "{color.text.primary.inactive.1}",
              "type": "color",
              "$description": "Text color for disabled primary tab - lighter gray (inactive)"
            }
          },
          "focus": {
            "ring": {
              "value": "{color.border.primary.subtle.2}",
              "type": "color",
              "$description": "Focus ring color for primary tab - light primary blue"
