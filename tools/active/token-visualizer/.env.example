# Password gate (Basic Auth via middleware). Set these in Vercel → Project → Settings → Environment Variables.
# Leave BOTH empty to disable the gate (e.g. for local dev or a public deploy).
VIZ_USER=highrise
VIZ_PASS=change-me

# Optional: override where the build script reads token JSON from.
# Defaults to ../../../tokens (repo root — the app lives in tools/active/token-visualizer),
# with fallbacks to ../tokens, ./tokens, and ../../tokens.
# TOKENS_DIR=../../../tokens
